{
  "name": "turboorder",
  "version": "0.1.0",
  "private": true,
  "description": "TurboOrder — Sales Management Platform",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:web": "pnpm --filter @turboorder/web dev",
    "dev:api": "pnpm --filter @turboorder/api dev",
    "build": "pnpm -r build",
    "build:web": "pnpm --filter @turboorder/web build",
    "build:api": "pnpm --filter @turboorder/api build",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "clean": "pnpm -r clean"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  }
}
